{
	"expo": {
		"name": "pdfcraft",
		"slug": "pdfcraft-mobile",
		"version": "0.3.5",
		"orientation": "portrait",
		"icon": "./assets/icons/icon.png",
		"scheme": "pdfcraftmobile",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "ru.mrchn.craft",
			"buildNumber": "72",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false,
				"CFBundleLocalizations": [
					"en",
					"ru"
				],
				"CFBundleDevelopmentRegion": "en"
			}
		},
		"plugins": [
			"expo-router",
			"expo-localization",
			"expo-font",
			"./plugins/settingsbundle.js"
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true,
			"tsconfigPaths": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "dcc55f1b-8b92-4df7-8307-dc277430a48a"
			}
		}
	}
}