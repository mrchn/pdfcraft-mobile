{
	"expo": {
		"name": "pdfcraft",
		"slug": "pdfcraft-mobile",
		"version": "0.2.0",
		"orientation": "portrait",
		"icon": "./app/icons/icon.png",
		"scheme": "pdfcraftmobile",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "ru.mrchn.craft",
			"buildNumber": "3",
			"infoPlist": {
				"ITSAppUsesNonExemptEncryption": false
			}
		},
		"android": {
			"package": "ru.mrchn.craft",
			"versionCode": 3,
			"adaptiveIcon": {
				"backgroundColor": "#FFFFFF",
				"foregroundImage":
					"./app/icons/android-icon-foreground.png",
				"monochromeImage":
					"./app/icons/android-icon-monochrome.png"
			},
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false
		},
		"plugins": [
			"expo-router",
			"./plugins/settingsbundle.js"
		],
		"experiments": {
			"typedRoutes": true,
			"reactCompiler": true,
			"tsconfigPaths": true
		},
		"extra": {
			"router": {},
			"eas": {
				"projectId": "dcc55f1b-8b92-4df7-8307-dc277430a48a"
			}
		}
	}
}